# Ghost Proxy Configuration

# Proxy Server
HOST=0.0.0.0
PORT=8000

# LLM Provider (openai, anthropic, google)
LLM_PROVIDER=openai

# API Keys (user provides their own)
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-key-here

# Privacy Settings
PRIVACY_MODE=strict
# Options: strict, balanced, permissive

# Logging
LOG_LEVEL=INFO
LOG_ENCRYPTION_KEY=your-32-char-key-here

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60